# Required for live LLM extraction. If empty, live demo fails with a clear message.
APP_NAME=LandScout Agent（地脉智能体）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional. Only OpenAI SDK calls use this proxy; public-source crawlers do not.
# Example for Clash/V2Ray HTTP mixed port:
# OPENAI_PROXY=http://127.0.0.1:7890
OPENAI_PROXY=

# Optional. If empty, Shanghai gazetteer fallback geocoding is used.
AMAP_KEY=

# Default docker-compose database. SQLite fallback is used when DATABASE_URL is unset.
DATABASE_URL=postgresql+psycopg://gov:gov@localhost:5432/landscout_agent

USER_AGENT=landscout-agent/0.1 (+public-source-research; contact=example@example.com)
REQUEST_TIMEOUT_SECONDS=30
